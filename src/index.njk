---
layout: layouts/base.njk
title: Where Smart Money Meets Smart Travel
---

{# Grab the latest posts #}
{%- set allPosts = collections.posts -%}
{%- set featured = allPosts[0] -%}
{%- set sidebarPosts = allPosts | limit(4) -%}
{%- set travelPosts = collections.travel -%}
{%- set financePosts = collections.finance -%}

<!-- HERO -->
<section class="hero">
  {% if featured %}
  <a href="{{ featured.url }}" class="hero-featured">
    <img src="{{ featured.data.featuredImage }}" alt="{{ featured.data.title }}">
    <div class="hero-featured-overlay">
      <span class="tag">{{ featured.data.category }}</span>
      <h2 class="hero-title-lg">{{ featured.data.title }}</h2>
      <p class="hero-meta">{{ featured.date | dateDisplay }} &nbsp;·&nbsp; {{ featured.data.readTime | default("5") }} min read</p>
    </div>
  </a>
  {% endif %}

  <div class="hero-sidebar">
    {%- for post in sidebarPosts %}
    <a href="{{ post.url }}" class="hero-sidebar-item">
      <img src="{{ post.data.featuredImage }}" alt="{{ post.data.title }}">
      <div>
        <span class="tag {% if post.data.parentCategory == 'Personal Finance' %}navy{% endif %}">{{ post.data.category }}</span>
        <div class="hero-sidebar-title">{{ post.data.title }}</div>
        <div class="hero-sidebar-meta">{{ post.date | dateDisplay }}</div>
      </div>
    </a>
    {%- endfor %}
  </div>
</section>

<!-- MISSION / VISION SECTION -->
<section style="background: var(--cream); border-bottom: 1px solid var(--border); padding: 4rem 0;">
  <style>
    .mvv-grid {
      display: grid;
      grid-template-columns: 1fr 1px 1fr;
      gap: 0;
      max-width: 800px;
      margin: 0 auto;
    }
    .mvv-divider { background: var(--border); }
    .mvv-mission { padding: 0 2.5rem 0 0; }
    .mvv-vision { padding: 0 0 0 2.5rem; }
    @media (max-width: 768px) {
      .mvv-grid {
        grid-template-columns: 1fr;
      }
      .mvv-divider {
        height: 1px;
        width: 100%;
        margin: 1.75rem 0;
      }
      .mvv-mission { padding: 0; }
      .mvv-vision { padding: 0; }
    }
  </style>
  <div class="container">
    <div class="mvv-grid">

      <!-- Mission -->
      <div class="mvv-mission">
        <div style="font-size: 10px; font-weight: 500; letter-spacing: .18em; text-transform: uppercase; color: var(--gold); margin-bottom: 1rem;">Our Mission</div>
        <div style="font-family: var(--font-display); font-size: 1.2rem; font-weight: 600; color: var(--navy); line-height: 1.35; margin-bottom: .85rem;">Help people travel more and stress about money less.</div>
        <p style="font-size: 14px; color: var(--slate); line-height: 1.75;">We deliver honest, well-researched guides that make the world feel more accessible and financial decisions feel less overwhelming.</p>
      </div>

      <!-- Divider -->
      <div class="mvv-divider"></div>

      <!-- Vision -->
      <div class="mvv-vision">
        <div style="font-size: 10px; font-weight: 500; letter-spacing: .18em; text-transform: uppercase; color: var(--gold); margin-bottom: 1rem;">Our Vision</div>
        <div style="font-family: var(--font-display); font-size: 1.2rem; font-weight: 600; color: var(--navy); line-height: 1.35; margin-bottom: .85rem;">A world where smart travel and smart money are the same pursuit.</div>
        <p style="font-size: 14px; color: var(--slate); line-height: 1.75;">The people who want to see more of the world deserve the financial foundation to do it well — and do it often.</p>
      </div>



    </div>
  </div>
</section>

<!-- LATEST TRAVEL -->
<section class="section">
  <div class="container">
    <div class="section-header">
      <h2>Latest Travel</h2>
      <div class="section-header-line"></div>
      <a href="/travel/">All Travel →</a>
    </div>
    <div class="split-section">
      <div>
        {%- for post in travelPosts | limit(3) %}
        <a href="{{ post.url }}" class="card-h">
          <img src="{{ post.data.featuredImage }}" alt="{{ post.data.title }}">
          <div>
            <div class="card-meta">
              <span class="tag">{{ post.data.category }}</span>
              <span class="card-date">{{ post.date | dateDisplay }}</span>
            </div>
            <div class="card-title lg">{{ post.data.title }}</div>
            <p class="card-excerpt">{{ post.data.description }}</p>
          </div>
        </a>
        {%- endfor %}
      </div>

      <aside>
        <div class="sidebar-widget">
          <h3>Trending This Week</h3>
          {%- for post in allPosts | limit(3) %}
          <a href="{{ post.url }}" class="sidebar-list-item" style="text-decoration:none;">
            <img src="{{ post.data.featuredImage }}" alt="{{ post.data.title }}">
            <div>
              <div class="sidebar-list-title">{{ post.data.title }}</div>
              <div class="sidebar-list-meta">{{ post.data.category }}</div>
            </div>
          </a>
          {%- endfor %}
        </div>

        <div class="sidebar-widget" style="background:var(--navy);border-color:var(--navy);">
          <h3 style="color:var(--gold);border-color:rgba(255,255,255,.1);">The Weekly Edit</h3>
          <p style="font-size:13px;color:rgba(255,255,255,.65);line-height:1.6;margin-bottom:1rem;">One email a week. The best articles, deals, and points tips — curated just for you.</p>
          <a href="#newsletter" style="display:block;text-align:center;background:var(--gold);color:#fff;padding:10px;border-radius:2px;font-size:12px;font-weight:500;letter-spacing:.06em;text-transform:uppercase;text-decoration:none;">Subscribe Free</a>
        </div>
      </aside>
    </div>
  </div>
</section>

<!-- PERSONAL FINANCE -->
<section class="section" style="background:var(--cream);">
  <div class="container">
    <div class="section-header">
      <h2>Personal Finance</h2>
      <div class="section-header-line"></div>
      <a href="/finance/">All Finance →</a>
    </div>

    <div class="card-grid cols-3" style="margin-bottom:2.5rem;">
      {%- for post in financePosts | limit(2) %}
      <a href="{{ post.url }}" style="text-decoration:none;" class="card">
        <div class="card-img">
          <img src="{{ post.data.featuredImage }}" alt="{{ post.data.title }}">
        </div>
        <div class="card-meta">
          <span class="tag navy">{{ post.data.category }}</span>
          <span class="card-date">{{ post.date | dateDisplay }}</span>
        </div>
        <div class="card-title">{{ post.data.title }}</div>
        <p class="card-excerpt">{{ post.data.description }}</p>
      </a>
      {%- endfor %}

      <!-- Finance topics nav card -->
      <div style="background:var(--navy);padding:1.5rem;border-radius:2px;display:flex;flex-direction:column;justify-content:space-between;">
        <div>
          <div style="font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--gold);margin-bottom:1rem;font-weight:500;">Finance Topics</div>
          <a href="/investing/" style="display:flex;justify-content:space-between;align-items:center;padding:.7rem 0;border-bottom:1px solid rgba(255,255,255,.1);color:#fff;font-size:14px;text-decoration:none;">Investment Accounts <span style="color:var(--gold);">→</span></a>
          <a href="/budgeting/" style="display:flex;justify-content:space-between;align-items:center;padding:.7rem 0;border-bottom:1px solid rgba(255,255,255,.1);color:#fff;font-size:14px;text-decoration:none;">Budgeting <span style="color:var(--gold);">→</span></a>
          <a href="/credit-points/" style="display:flex;justify-content:space-between;align-items:center;padding:.7rem 0;border-bottom:1px solid rgba(255,255,255,.1);color:#fff;font-size:14px;text-decoration:none;">Credit &amp; Points <span style="color:var(--gold);">→</span></a>
          <a href="/finance/" style="display:flex;justify-content:space-between;align-items:center;padding:.7rem 0;color:#fff;font-size:14px;text-decoration:none;">Tax &amp; Retirement <span style="color:var(--gold);">→</span></a>
        </div>
        <a href="/finance/" style="display:block;text-align:center;background:var(--gold);color:#fff;padding:9px;border-radius:2px;font-size:12px;font-weight:500;letter-spacing:.06em;text-transform:uppercase;margin-top:1.5rem;text-decoration:none;">All Finance Articles</a>
      </div>
    </div>

    <div class="card-grid cols-4">
      <div class="finance-card">
        <div class="icon"><i class="ti ti-credit-card" aria-hidden="true"></i></div>
        <h3>Credit Card Rewards</h3>
        <p>Maximize points, miles, and cash back with the right cards for your spending style.</p>
      </div>
      <div class="finance-card">
        <div class="icon"><i class="ti ti-chart-line" aria-hidden="true"></i></div>
        <h3>Investment Accounts</h3>
        <p>From 401(k)s to Roth IRAs — how to pick the right account and grow your wealth.</p>
      </div>
      <div class="finance-card">
        <div class="icon"><i class="ti ti-calculator" aria-hidden="true"></i></div>
        <h3>Budgeting</h3>
        <p>Practical frameworks to manage your money so you can afford to live — and travel — well.</p>
      </div>
      <div class="finance-card">
        <div class="icon"><i class="ti ti-building-bank" aria-hidden="true"></i></div>
        <h3>Tax Strategy</h3>
        <p>Keep more of what you earn. Smart tax moves for travelers, freelancers, and families.</p>
      </div>
    </div>
  </div>
</section>

<!-- NEWSLETTER -->
<section class="newsletter-section">
  <div class="container">
    <div class="newsletter-inner">
      <div class="newsletter-text">
        <div class="section-eyebrow">Free Newsletter</div>
        <h2 class="newsletter-heading">The Weekly Edit</h2>
        <p class="newsletter-sub">Smart travel and money insights, every week. No spam, no fluff — just the good stuff. Free forever.</p>
      </div>
      <div class="newsletter-form-wrap">
        <script src="https://f.convertkit.com/ckjs/ck.5.js"></script>
        <form action="https://app.kit.com/forms/9480612/subscriptions"
              class="seva-form kit-form-homepage"
              method="post"
              data-sv-form="9480612"
              data-uid="018ad640ca"
              data-format="inline"
              data-version="5">
          <ul class="formkit-alert formkit-alert-error" data-element="errors" data-group="alert"></ul>
          <div class="kit-fields" data-element="fields">
            <input class="kit-input"
                   name="email_address"
                   aria-label="Your email address"
                   placeholder="Your email address"
                   required
                   type="email">
            <button data-element="submit" class="kit-btn">
              <div class="formkit-spinner"><div></div><div></div><div></div></div>
              <span>Subscribe Free</span>
            </button>
          </div>
          <p class="kit-disclaimer">Join smart travelers and savers. Unsubscribe anytime.</p>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
.newsletter-section {
  background: var(--navy);
  padding: 4rem 2rem;
}

.newsletter-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: center;
}

.newsletter-text .section-eyebrow {
  font-size: 11px;
  font-weight: 500;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: .75rem;
}

.newsletter-heading {
  font-family: 'Playfair Display', serif;
  font-size: 2rem;
  font-weight: 600;
  color: #fff;
  margin-bottom: .75rem;
  line-height: 1.2;
}

.newsletter-sub {
  font-size: 15px;
  color: rgba(255,255,255,.6);
  line-height: 1.7;
  margin: 0;
}

.kit-fields {
  display: flex;
  gap: 0;
  margin-bottom: .75rem;
}

.kit-input {
  flex: 1;
  background: rgba(255,255,255,.08);
  border: 1px solid rgba(255,255,255,.15);
  border-right: none;
  color: #fff;
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  padding: 12px 16px;
  border-radius: 2px 0 0 2px;
  outline: none;
  transition: border-color 200ms;
}

.kit-input::placeholder {
  color: rgba(255,255,255,.4);
}

.kit-input:focus {
  border-color: var(--gold);
  background: rgba(255,255,255,.12);
}

.kit-btn {
  background: var(--gold);
  color: #fff;
  font-family: 'DM Sans', sans-serif;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: .1em;
  text-transform: uppercase;
  border: none;
  padding: 12px 20px;
  border-radius: 0 2px 2px 0;
  cursor: pointer;
  white-space: nowrap;
  transition: background 200ms;
  position: relative;
}

.kit-btn:hover {
  background: #b37d22;
}

.kit-disclaimer {
  font-size: 12px;
  color: rgba(255,255,255,.35);
  margin: 0;
}

.formkit-alert-error {
  list-style: none;
  padding: 0;
  margin: 0 0 .75rem;
  font-size: 13px;
  color: #f2643b;
}

.formkit-alert:empty {
  display: none;
}

.formkit-spinner {
  display: none;
}

@media (max-width: 768px) {
  .newsletter-inner {
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
}

@media (max-width: 640px) {
  .newsletter-section {
    padding: 2.5rem 1.25rem;
  }

  .kit-fields {
    flex-direction: column;
    gap: .75rem;
  }

  .kit-input {
    border-right: 1px solid rgba(255,255,255,.15);
    border-radius: 2px;
  }

  .kit-btn {
    border-radius: 2px;
    padding: 14px 20px;
  }
}
</style>
