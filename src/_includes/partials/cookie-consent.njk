<!-- COOKIE CONSENT BANNER -->
<div id="cookieBanner" style="display:none; position:fixed; bottom:0; left:0; right:0; background:var(--navy); color:#fff; z-index:9999; padding:1.25rem 1.5rem; box-shadow:0 -4px 20px rgba(0,0,0,.15);">
  <div style="max-width:1200px; margin:0 auto; display:flex; align-items:center; justify-content:space-between; gap:1.5rem; flex-wrap:wrap;">
    <p style="font-size:13px; color:rgba(255,255,255,.8); line-height:1.6; margin:0; flex:1; min-width:200px;">
      We use cookies and analytics to improve your experience and understand how our site is used. By continuing, you agree to our <a href="/privacy/" style="color:var(--gold); text-decoration:underline;">Privacy Policy</a>.
    </p>
    <div style="display:flex; gap:.75rem; flex-shrink:0;">
      <button id="cookieDecline" style="background:transparent; color:rgba(255,255,255,.6); border:1px solid rgba(255,255,255,.2); padding:8px 16px; border-radius:2px; font-family:var(--font-body); font-size:12px; font-weight:500; letter-spacing:.06em; text-transform:uppercase; cursor:pointer;">
        Decline
      </button>
      <button id="cookieAccept" style="background:var(--gold); color:#fff; border:none; padding:8px 20px; border-radius:2px; font-family:var(--font-body); font-size:12px; font-weight:500; letter-spacing:.06em; text-transform:uppercase; cursor:pointer;">
        Accept
      </button>
    </div>
  </div>
</div>
