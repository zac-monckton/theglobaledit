<style>
  /* ─── DROPDOWN NAV ─────────────────────────────────────── */
  .nav-item { position: relative; padding-bottom: 8px; margin-bottom: -8px; }
  .nav-item > a { display: flex; align-items: center; gap: 4px; }
  .nav-item > a::after {
    content: '';
    display: inline-block;
    width: 6px; height: 6px;
    border-right: 1.5px solid currentColor;
    border-bottom: 1.5px solid currentColor;
    transform: rotate(45deg) translateY(-2px);
    transition: transform .2s;
  }
  .nav-item:hover > a::after { transform: rotate(-135deg) translateY(-2px); }
  .dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    background: var(--warm-white);
    border: 1px solid var(--border);
    border-top: 2px solid var(--gold);
    border-radius: 0 0 3px 3px;
    box-shadow: 0 8px 30px rgba(0,0,0,.1);
    min-width: 200px;
    z-index: 200;
    padding: .5rem 0;
  }
  .dropdown::before {
    content: '';
    position: absolute;
    top: -12px; left: 0; right: 0; height: 12px;
  }
  .nav-item:hover .dropdown { display: block; }
  .nav-item:not(:hover) .dropdown { pointer-events: none; }
  .dropdown-section { padding: .4rem 0; border-bottom: 1px solid var(--border); }
  .dropdown-section:last-child { border-bottom: none; }
  .dropdown-label { font-size: 9px; font-weight: 500; letter-spacing: .12em; text-transform: uppercase; color: var(--gold); padding: .4rem 1.25rem .2rem; }
  .dropdown a { display: block !important; padding: .5rem 1.25rem !important; font-size: 13px !important; font-weight: 400 !important; letter-spacing: .02em !important; text-transform: none !important; color: var(--slate) !important; transition: color .15s, background .15s !important; white-space: nowrap; }
  .dropdown a:hover { color: var(--navy) !important; background: var(--cream); }

  /* ─── MOBILE MENU ───────────────────────────────────────── */
  .mobile-menu { display: none; background: var(--warm-white); border-top: 1px solid var(--border); padding: .5rem 0 1rem; }
  .mobile-menu.open { display: block; }

  /* Top-level toggle rows */
  .mobile-toggle {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 1.5rem; cursor: pointer;
    border-bottom: 1px solid var(--border);
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
  }
  .mobile-toggle-label {
    font-size: 13px; font-weight: 600; letter-spacing: .06em;
    text-transform: uppercase; color: var(--navy); text-decoration: none;
  }
  .mobile-toggle-arrow {
    width: 28px; height: 28px; display: flex; align-items: center; justify-content: center;
    color: var(--gold); font-size: 18px; flex-shrink: 0;
    transition: transform .25s ease;
  }
  .mobile-toggle.open .mobile-toggle-arrow { transform: rotate(180deg); }

  /* Dropdown panels */
  .mobile-dropdown { display: none; background: var(--cream); border-bottom: 1px solid var(--border); }
  .mobile-dropdown.open { display: block; }
  .mobile-dropdown-label {
    font-size: 9px; font-weight: 600; letter-spacing: .14em; text-transform: uppercase;
    color: var(--gold); padding: .85rem 1.5rem .2rem;
  }
  .mobile-dropdown a {
    display: block; padding: 10px 1.5rem 10px 2rem;
    font-size: 13px; font-weight: 400; color: var(--slate);
    border-bottom: 1px solid var(--border); text-decoration: none;
  }
  .mobile-dropdown a:last-child { border-bottom: none; }
  .mobile-dropdown a:active { background: var(--border); }

  /* Company links */
  .mobile-company-links { padding: .5rem 0; }
  .mobile-company-links a {
    display: block; padding: 11px 1.5rem;
    font-size: 13px; font-weight: 400; color: var(--slate);
    border-bottom: 1px solid var(--border); text-decoration: none;
  }
  .mobile-company-links a:last-child { border-bottom: none; }
  .mobile-company-links a.gold { color: var(--gold); font-weight: 500; }

  #mobileMenuBtn {
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
    min-width: 44px; min-height: 44px;
    flex-direction: column; justify-content: center; align-items: center;
  }
  @media (max-width: 640px) {
    #mobileMenuBtn { display: flex; }
  }
</style>

