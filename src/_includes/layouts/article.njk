---
layout: layouts/base.njk
---

<!-- ARTICLE HERO -->
<div class="article-hero">
  <img src="{{ featuredImage }}" alt="{{ title }}">
  <div class="article-hero-overlay">
    <div class="article-hero-content">
      <div style="margin-bottom: .75rem;">
        <span class="tag">{{ category }}</span>
        {% if subcategory %}&nbsp;<span class="tag">{{ subcategory }}</span>{% endif %}
      </div>
      <h1 class="article-headline">{{ title }}</h1>
      <div class="article-byline">
        <span>By {{ author | default("The Global Edit") }}</span>
        <span>{{ date | dateDisplay }}</span>
        <span>{{ readTime | default("5") }} min read</span>
      </div>
    </div>
  </div>
</div>

<!-- ARTICLE BODY + SIDEBAR -->
<div class="article-layout">
  <article class="article-content">
    {{ content | safe }}

    <p style="margin-top:2.5rem;padding-top:1rem;border-top:1px solid var(--border);font-size:12px;color:var(--slate-light);line-height:1.6;"><strong style="font-weight:500;color:var(--slate);">Editorial Disclosure:</strong> This article was written with the assistance of artificial intelligence and reflects the author's honest research, experience, and editorial judgment. AI-assisted content on The Global Edit is always reviewed, edited, and approved by our editorial team before publication.</p>
  </article>

  <aside class="article-sidebar">
    <!-- Table of Contents -->
    {% if toc %}
    <div class="sidebar-widget">
      <h3>Table of Contents</h3>
      {% for item in toc %}
      <a href="#section-{{ loop.index }}" class="toc-item">
        <span class="toc-num">{{ loop.index }}</span>
        {{ item }}
      </a>
      {% endfor %}
    </div>
    {% endif %}

    <!-- Share -->
    <div class="sidebar-widget">
      <h3>Share This Article</h3>
      <div style="display:flex;flex-direction:column;gap:.5rem;">
        <a href="https://www.facebook.com/sharer/sharer.php?u={{ page.url }}" target="_blank" rel="noopener" style="display:flex;align-items:center;gap:.75rem;padding:9px 12px;border:1px solid var(--border);border-radius:2px;font-size:13px;">
          <i class="ti ti-brand-facebook" style="color:#1877F2;font-size:17px;" aria-hidden="true"></i> Share on Facebook
        </a>
        <a href="https://twitter.com/intent/tweet?url={{ page.url }}&text={{ title }}" target="_blank" rel="noopener" style="display:flex;align-items:center;gap:.75rem;padding:9px 12px;border:1px solid var(--border);border-radius:2px;font-size:13px;">
          <i class="ti ti-brand-x" style="font-size:17px;" aria-hidden="true"></i> Post on X
        </a>
      </div>
    </div>

    <!-- Newsletter CTA -->
<div class="sidebar-newsletter">
  <div class="sidebar-newsletter-eyebrow">Free Newsletter</div>
  <div class="sidebar-newsletter-heading">The Weekly Edit</div>
  <p class="sidebar-newsletter-sub">Smart travel and money insights every week. Free.</p>
  <form action="https://app.kit.com/forms/9480612/subscriptions"
        class="seva-form kit-form-sidebar"
        method="post"
        data-sv-form="9480612"
        data-uid="018ad640ca"
        data-format="inline"
        data-version="5">
    <ul class="formkit-alert formkit-alert-error" data-element="errors" data-group="alert"></ul>
    <div data-element="fields">
      <input class="sidebar-kit-input"
             name="email_address"
             aria-label="Your email address"
             placeholder="Your email address"
             required
             type="email">
      <button data-element="submit" class="sidebar-kit-btn">
        <div class="formkit-spinner"><div></div><div></div><div></div></div>
        <span>Subscribe Free</span>
      </button>
    </div>
  </form>
  <p class="sidebar-kit-disclaimer">No spam. Unsubscribe anytime.</p>
</div>

<style>
.sidebar-newsletter {
  background: var(--navy);
  border-radius: 4px;
  padding: 1.5rem;
  margin-bottom: 1.5rem;
}

.sidebar-newsletter-eyebrow {
  font-size: 10px;
  font-weight: 500;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: .5rem;
}

.sidebar-newsletter-heading {
  font-family: 'Playfair Display', serif;
  font-size: 1.2rem;
  font-weight: 600;
  color: #fff;
  margin-bottom: .5rem;
}

.sidebar-newsletter-sub {
  font-size: 13px;
  color: rgba(255,255,255,.6);
  line-height: 1.6;
  margin-bottom: 1rem;
}

.sidebar-kit-input {
  width: 100%;
  box-sizing: border-box;
  background: rgba(255,255,255,.08);
  border: 1px solid rgba(255,255,255,.15);
  color: #fff;
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  padding: 10px 12px;
  border-radius: 2px;
  outline: none;
  margin-bottom: .5rem;
  transition: border-color 200ms;
}

.sidebar-kit-input::placeholder {
  color: rgba(255,255,255,.4);
}

.sidebar-kit-input:focus {
  border-color: var(--gold);
  background: rgba(255,255,255,.12);
}

.sidebar-kit-btn {
  width: 100%;
  background: var(--gold);
  color: #fff;
  font-family: 'DM Sans', sans-serif;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: .1em;
  text-transform: uppercase;
  border: none;
  padding: 11px 16px;
  border-radius: 2px;
  cursor: pointer;
  transition: background 200ms;
  position: relative;
}

.sidebar-kit-btn:hover {
  background: #b37d22;
}

.sidebar-kit-disclaimer {
  font-size: 11px;
  color: rgba(255,255,255,.3);
  margin: .5rem 0 0;
  text-align: center;
}
</style>


<!-- RELATED ARTICLES -->
<div class="related-section" style="background:var(--cream);padding:3.5rem 0;border-top:1px solid var(--border);">
  <div class="container">
    <div class="section-header">
      <h2>You Might Also Like</h2>
      <div class="section-header-line"></div>
    </div>
    <div class="card-grid cols-3">
      {%- set relatedPosts = collections.posts | selectattr("data.category", "equalto", category) | reject("equalto", page) | list -%}
      {%- for post in relatedPosts | limit(3) %}
      <a href="{{ post.url }}" style="text-decoration:none;" class="card">
        <div class="card-img">
          <img src="{{ post.data.featuredImage }}" alt="{{ post.data.title }}">
        </div>
        <div class="card-meta">
          <span class="tag">{{ post.data.category }}</span>
          <span class="card-date">{{ post.date | dateDisplay }}</span>
        </div>
        <div class="card-title">{{ post.data.title }}</div>
        <p class="card-excerpt">{{ post.data.description }}</p>
      </a>
      {%- endfor %}
    </div>
  </div>
</div>
