---
layout: layouts/base.njk
---

{# Filter posts — parent pages use filterByParent, subcategory pages use filterByCategory #}
{%- if useParentFilter %}
  {%- set categoryPosts = collections.posts | filterByParent(categoryName) -%}
{%- else %}
  {%- set categoryPosts = collections.posts | filterByCategory(categoryName) -%}
{%- endif %}

<!-- CATEGORY HERO -->
<div style="background: var(--navy); padding: 3.5rem 0; border-bottom: 1px solid var(--border);">
  <div class="container">
    <div style="max-width: 680px;">
      {% if parentCategory %}
      {% if parentCategory == 'Personal Finance' %}
        {% set parentUrl = '/finance/' %}
      {% elif parentCategory == 'Travel' %}
        {% set parentUrl = '/travel/' %}
      {% else %}
        {% set parentUrl = '/' + parentCategory | lower | replace(' ', '-') + '/' %}
      {% endif %}
      <a href="{{ parentUrl }}" style="font-size:11px; letter-spacing:.1em; text-transform:uppercase; color:var(--gold); font-weight:500; text-decoration:none;">
        ← {{ parentCategory }}
      </a>
      {% endif %}
      <h1 style="font-family: var(--font-display); font-size: 2.5rem; font-weight: 600; color: #fff; margin: .75rem 0 1rem; line-height: 1.2;">{{ categoryName }}</h1>
      <p style="font-size: 16px; color: rgba(255,255,255,.65); line-height: 1.7;">{{ categoryDescription }}</p>
      <div style="margin-top: 1.25rem; font-size: 12px; color: rgba(255,255,255,.4); letter-spacing: .06em; text-transform: uppercase;">
        {{ categoryPosts | length }} {% if categoryPosts | length == 1 %}Article{% else %}Articles{% endif %}
      </div>
    </div>
  </div>
</div>

<!-- ARTICLES -->
<section style="padding: 3.5rem 0;">
  <div class="container">
    {% if categoryPosts | length > 0 %}

      {# Featured top article #}
      {%- set featured = categoryPosts[0] -%}
<style>
  .featured-card {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    min-height: 380px;
    border: 1px solid var(--border);
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 2.5rem;
    text-decoration: none;
    color: inherit;
    transition: box-shadow .2s;
  }
  .featured-card:hover { box-shadow: 0 8px 30px rgba(0,0,0,.1); }
  .featured-card-img { position: relative; overflow: hidden; min-height: 240px; }
  .featured-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s; }
  .featured-card:hover .featured-card-img img { transform: scale(1.03); }
  .featured-card-body {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--cream);
  }
  .featured-card-title {
    font-family: var(--font-display);
    font-size: 1.7rem;
    font-weight: 600;
    line-height: 1.2;
    color: var(--navy);
    margin-bottom: 1rem;
  }
  @media (max-width: 640px) {
    .featured-card {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .featured-card-img { min-height: 200px; max-height: 220px; }
    .featured-card-body { padding: 1.25rem; }
    .featured-card-title { font-size: 1.2rem; }
  }
</style>

      <a href="{{ featured.url }}" class="featured-card">
        <div class="featured-card-img">
          <img src="{{ featured.data.featuredImage }}" alt="{{ featured.data.title }}">
        </div>
        <div class="featured-card-body">
          <div style="margin-bottom: .75rem;">
            <span class="tag filled">Featured</span>
          </div>
          <div class="featured-card-title">{{ featured.data.title }}</div>
          <p style="font-size: 14px; color: var(--slate); line-height: 1.7; margin-bottom: 1.25rem;">{{ featured.data.description }}</p>
          <div style="font-size: 12px; color: var(--slate-light);">{{ featured.date | dateDisplay }} &nbsp;·&nbsp; {{ featured.data.readTime | default("5") }} min read</div>
          <div style="margin-top: 1.5rem; font-size: 12px; font-weight: 500; letter-spacing: .08em; text-transform: uppercase; color: var(--gold);">Read Article →</div>
        </div>
      </a>

      {# Rest of articles in grid #}
      {% if categoryPosts | length > 1 %}
      <div class="section-header">
        <h2>All {{ categoryName }} Articles</h2>
        <div class="section-header-line"></div>
      </div>
      <div class="card-grid cols-3">
        {%- for post in categoryPosts | slice(1) %}
        <a href="{{ post.url }}" style="text-decoration:none;" class="card">
          <div class="card-img">
            <img src="{{ post.data.featuredImage }}" alt="{{ post.data.title }}">
          </div>
          <div class="card-meta">
            <span class="tag">{{ post.data.category }}</span>
            <span class="card-date">{{ post.date | dateDisplay }}</span>
          </div>
          <div class="card-title">{{ post.data.title }}</div>
          <p class="card-excerpt">{{ post.data.description }}</p>
        </a>
        {%- endfor %}
      </div>
      {% endif %}

    {% else %}
      <!-- Empty state -->
      <div style="text-align: center; padding: 5rem 1.5rem;">
        <div style="font-size: 48px; margin-bottom: 1.5rem;">✈️</div>
        <h2 style="font-family: var(--font-display); font-size: 1.7rem; font-weight: 600; color: var(--navy); margin-bottom: 1rem;">Coming Soon</h2>
        <p style="font-size: 16px; color: var(--slate); max-width: 400px; margin: 0 auto 2rem; line-height: 1.7;">We're working on {{ categoryName }} content. Subscribe to be the first to know when new articles are published.</p>
        <a href="/#newsletter" style="display:inline-block; background: var(--navy); color: #fff; padding: 12px 28px; border-radius: 2px; font-size: 12px; font-weight: 500; letter-spacing: .08em; text-transform: uppercase; text-decoration: none;">Subscribe for Updates</a>
      </div>
    {% endif %}
  </div>
</section>

<!-- NEWSLETTER -->
<section class="newsletter" id="newsletter">
  <div class="newsletter-inner">
    <h2>The Weekly Edit</h2>
    <p>The best {{ categoryName }} articles, travel guides, and money tips — every week, free.</p>
    <form class="newsletter-form" onsubmit="return false;">
      <input type="email" placeholder="your@email.com" aria-label="Email address">
      <button type="submit">Subscribe →</button>
    </form>
    <p class="newsletter-note">No spam. Unsubscribe anytime.</p>
  </div>
</section>
